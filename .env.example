# Site URL utilisée pour les balises OG / canonical
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Facebook Pixel ID (laisser vide pour désactiver)
NEXT_PUBLIC_FB_PIXEL_ID=

# Google Analytics 4 Measurement ID (G-XXXXXXX)
NEXT_PUBLIC_GA4_ID=

# CTA principal — URL Cal.com de fallback (utilisé si JS désactivé)
NEXT_PUBLIC_CALENDLY_URL=https://cal.com/titouan.grow/call-coworking

# Lien Cal.com pour l'embed inline (format username/event-type, sans https://cal.com/)
NEXT_PUBLIC_CALCOM_LINK=titouan.grow/call-coworking

# CTA checkout — URL de paiement (Stripe Payment Link, Systeme.io, etc.)
NEXT_PUBLIC_CHECKOUT_URL=

# YouTube video ID pour la page /merci (juste l'ID, pas l'URL complète)
NEXT_PUBLIC_MERCI_YOUTUBE_ID=YOUR_VIDEO_ID

# Supabase — server side
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJ...

# Supabase — client side (optionnel, on utilise principalement le service_role server-side)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJ...

# Mot de passe pour accéder au dashboard /tracking
DASHBOARD_PASSWORD=change-me-please
