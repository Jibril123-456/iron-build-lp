# =====================================================================
# Site
# =====================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =====================================================================
# Cal.com
# =====================================================================
# Lien Cal.com pour l'embed inline (format username/event-type, sans https://cal.com/)
NEXT_PUBLIC_CALCOM_LINK=titouan.grow/call-coworking
# URL Cal.com complète (fallback si JS désactivé)
NEXT_PUBLIC_CALENDLY_URL=https://cal.com/titouan.grow/call-coworking

# =====================================================================
# Page /merci — vidéo YouTube affichée après booking
# Met juste l'ID (la partie après v= dans l'URL YouTube)
# =====================================================================
NEXT_PUBLIC_MERCI_YOUTUBE_ID=YOUR_VIDEO_ID

# =====================================================================
# Supabase — server side uniquement
# Récupère ces deux valeurs dans Supabase > Settings > API (ou API Keys)
#   - SUPABASE_URL              = "Project URL"
#   - SUPABASE_SERVICE_ROLE_KEY = clé "secret" (anciennement "service_role")
# JAMAIS exposer la secret key côté navigateur (pas de prefix NEXT_PUBLIC_).
# =====================================================================
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJ...

# =====================================================================
# Mot de passe pour accéder au dashboard /tracking
# Choisis un mot de passe long et unique.
# =====================================================================
DASHBOARD_PASSWORD=change-me-please

# =====================================================================
# Tracking tiers (optionnels — laisser vide pour désactiver)
# =====================================================================
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_GA4_ID=

# =====================================================================
# CTA checkout (optionnel — pas utilisé sur cette LP, le CTA passe par Cal.com)
# =====================================================================
NEXT_PUBLIC_CHECKOUT_URL=
